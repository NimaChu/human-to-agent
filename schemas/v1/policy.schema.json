{
  "$defs": {
    "ActionClass": {
      "enum": [
        "read_only",
        "internal_write",
        "external_send",
        "irreversible",
        "forbidden"
      ],
      "title": "ActionClass",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "evidence_refs": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Evidence Refs",
      "type": "array"
    },
    "human_gate_refs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Human Gate Refs",
      "type": "array"
    },
    "id": {
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "links": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Links",
      "type": "array"
    },
    "owners": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "title": "Owners",
      "type": "array"
    },
    "permitted_action_classes": {
      "items": {
        "$ref": "#/$defs/ActionClass"
      },
      "minItems": 1,
      "title": "Permitted Action Classes",
      "type": "array"
    },
    "provenance": {
      "minLength": 1,
      "title": "Provenance",
      "type": "string"
    },
    "revision": {
      "minimum": 1,
      "title": "Revision",
      "type": "integer"
    },
    "rules": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "title": "Rules",
      "type": "array"
    },
    "schema_version": {
      "minLength": 1,
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "minLength": 1,
      "title": "Status",
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    },
    "workspace_id": {
      "minLength": 1,
      "title": "Workspace Id",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "id",
    "workspace_id",
    "revision",
    "status",
    "owners",
    "created_at",
    "updated_at",
    "provenance",
    "rules",
    "permitted_action_classes",
    "human_gate_refs"
  ],
  "title": "PolicySpec",
  "type": "object"
}
