{
  "$defs": {
    "AssessmentFact": {
      "enum": [
        "real_task",
        "basic_goal_understood",
        "inputs_identified",
        "outputs_identified",
        "manual_modifications_recorded",
        "initial_unknowns_recorded",
        "time_baseline_recorded",
        "initial_success_criteria",
        "owner_confirmed_usable",
        "third_party_understands_goal_output",
        "task_contract_exists",
        "skill_prototype_exists",
        "original_case_rerun",
        "manual_modifications_linked",
        "key_unknowns_classified",
        "next_case_plan_exists",
        "normal_paths_stable",
        "common_failures_detected",
        "result_evaluable",
        "skill_boundaries_clear",
        "independent_skill_run",
        "key_unknowns_managed",
        "skill_version_explainable",
        "end_to_end_harness_run",
        "steps_traceable",
        "harness_goal_and_completion",
        "context_defined",
        "state_defined",
        "policies_defined",
        "human_gates_defined",
        "exceptions_defined",
        "local_evaluators_defined",
        "final_evaluator_defined",
        "autonomy_approved",
        "noncreator_harness_run",
        "business_goal_clear",
        "task_contract_complete",
        "core_skill_validated",
        "unknowns_managed",
        "input_output_state_boundaries_clear",
        "key_exceptions_detectable",
        "high_risk_actions_have_human_gates",
        "stop_recovery_escalation_defined",
        "noncreator_can_maintain",
        "loop_readiness_conclusion"
      ],
      "title": "AssessmentFact",
      "type": "string"
    },
    "GateCheck": {
      "additionalProperties": false,
      "properties": {
        "evidence_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "fact": {
          "anyOf": [
            {
              "$ref": "#/$defs/AssessmentFact"
            },
            {
              "type": "null"
            }
          ]
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "next_action": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Next Action"
        },
        "requirement_id": {
          "minLength": 1,
          "title": "Requirement Id",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/GateStatus"
        }
      },
      "required": [
        "requirement_id",
        "fact",
        "status",
        "evidence_refs",
        "message"
      ],
      "title": "GateCheck",
      "type": "object"
    },
    "GateStatus": {
      "enum": [
        "satisfied",
        "gap",
        "indeterminate"
      ],
      "title": "GateStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "checks": {
      "items": {
        "$ref": "#/$defs/GateCheck"
      },
      "minItems": 1,
      "title": "Checks",
      "type": "array"
    },
    "target": {
      "minLength": 1,
      "title": "Target",
      "type": "string"
    }
  },
  "required": [
    "target",
    "checks"
  ],
  "title": "GateReport",
  "type": "object"
}
