{
  "$defs": {
    "EvidenceBasis": {
      "enum": [
        "observed",
        "inferred",
        "assumption",
        "unverified"
      ],
      "title": "EvidenceBasis",
      "type": "string"
    },
    "EvidenceType": {
      "enum": [
        "formal_rule",
        "real_case",
        "owner_confirmation",
        "system_definition",
        "historical_data",
        "risk_decision",
        "repeatable_validation"
      ],
      "title": "EvidenceType",
      "type": "string"
    },
    "UnknownCategory": {
      "enum": [
        "goal",
        "input",
        "rule",
        "judgment",
        "exception",
        "acceptance",
        "permission",
        "tool",
        "state",
        "boundary",
        "risk",
        "responsibility"
      ],
      "title": "UnknownCategory",
      "type": "string"
    },
    "UnknownClosure": {
      "additionalProperties": false,
      "properties": {
        "actor": {
          "minLength": 1,
          "title": "Actor",
          "type": "string"
        },
        "at": {
          "format": "date-time",
          "title": "At",
          "type": "string"
        },
        "conclusion": {
          "minLength": 1,
          "title": "Conclusion",
          "type": "string"
        },
        "disposition": {
          "$ref": "#/$defs/UnknownDisposition"
        },
        "evidence_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "title": "Evidence Refs",
          "type": "array"
        },
        "impact": {
          "minLength": 1,
          "title": "Impact",
          "type": "string"
        },
        "owner_id": {
          "minLength": 1,
          "title": "Owner Id",
          "type": "string"
        },
        "propagated_to": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Propagated To",
          "type": "array"
        }
      },
      "required": [
        "disposition",
        "owner_id",
        "actor",
        "at",
        "conclusion",
        "impact",
        "evidence_refs",
        "propagated_to"
      ],
      "title": "UnknownClosure",
      "type": "object"
    },
    "UnknownDisposition": {
      "enum": [
        "resolved",
        "accepted_risk",
        "human_only",
        "out_of_scope"
      ],
      "title": "UnknownDisposition",
      "type": "string"
    },
    "UnknownHistoryEntry": {
      "additionalProperties": false,
      "properties": {
        "actor": {
          "minLength": 1,
          "title": "Actor",
          "type": "string"
        },
        "at": {
          "format": "date-time",
          "title": "At",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "title": "Evidence Refs",
          "type": "array"
        },
        "from_status": {
          "$ref": "#/$defs/UnknownStatus"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "to_status": {
          "$ref": "#/$defs/UnknownStatus"
        }
      },
      "required": [
        "from_status",
        "to_status",
        "reason",
        "actor",
        "at",
        "evidence_refs"
      ],
      "title": "UnknownHistoryEntry",
      "type": "object"
    },
    "UnknownStatus": {
      "enum": [
        "new",
        "clarification",
        "evidence",
        "business_confirmation",
        "validation",
        "resolved",
        "accepted_risk",
        "human_only",
        "out_of_scope",
        "reopened"
      ],
      "title": "UnknownStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "affected_assets": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "title": "Affected Assets",
      "type": "array"
    },
    "allowed_closure_evidence": {
      "items": {
        "$ref": "#/$defs/EvidenceType"
      },
      "minItems": 1,
      "title": "Allowed Closure Evidence",
      "type": "array"
    },
    "automation_restriction": {
      "minLength": 1,
      "title": "Automation Restriction",
      "type": "string"
    },
    "category": {
      "$ref": "#/$defs/UnknownCategory"
    },
    "cheapest_probe": {
      "minLength": 1,
      "title": "Cheapest Probe",
      "type": "string"
    },
    "closure": {
      "anyOf": [
        {
          "$ref": "#/$defs/UnknownClosure"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "confidence_basis": {
      "$ref": "#/$defs/EvidenceBasis"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "description": {
      "minLength": 1,
      "title": "Description",
      "type": "string"
    },
    "evidence_refs": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Evidence Refs",
      "type": "array"
    },
    "expected_responder_role": {
      "minLength": 1,
      "title": "Expected Responder Role",
      "type": "string"
    },
    "fact_resolved": {
      "default": false,
      "title": "Fact Resolved",
      "type": "boolean"
    },
    "history": {
      "default": [],
      "items": {
        "$ref": "#/$defs/UnknownHistoryEntry"
      },
      "title": "History",
      "type": "array"
    },
    "id": {
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "impact_dimensions": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "title": "Impact Dimensions",
      "type": "array"
    },
    "impact_narrative": {
      "minLength": 1,
      "title": "Impact Narrative",
      "type": "string"
    },
    "links": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Links",
      "type": "array"
    },
    "occurrence_conditions": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "title": "Occurrence Conditions",
      "type": "array"
    },
    "owner_id": {
      "minLength": 1,
      "title": "Owner Id",
      "type": "string"
    },
    "owners": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "title": "Owners",
      "type": "array"
    },
    "prompt_patch": {
      "minLength": 1,
      "title": "Prompt Patch",
      "type": "string"
    },
    "provenance": {
      "minLength": 1,
      "title": "Provenance",
      "type": "string"
    },
    "revision": {
      "minimum": 1,
      "title": "Revision",
      "type": "integer"
    },
    "schema_version": {
      "minLength": 1,
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "minLength": 1,
      "title": "Status",
      "type": "string"
    },
    "title": {
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "unknown_status": {
      "$ref": "#/$defs/UnknownStatus"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    },
    "workspace_id": {
      "minLength": 1,
      "title": "Workspace Id",
      "type": "string"
    }
