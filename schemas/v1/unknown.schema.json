  "required": [
    "schema_version",
    "id",
    "workspace_id",
    "revision",
    "status",
    "owners",
    "created_at",
    "updated_at",
    "provenance",
    "title",
    "description",
    "category",
    "unknown_status",
    "impact_dimensions",
    "impact_narrative",
    "occurrence_conditions",
    "affected_assets",
    "confidence_basis",
    "owner_id",
    "expected_responder_role",
    "cheapest_probe",
    "prompt_patch",
    "automation_restriction",
    "allowed_closure_evidence"
  ],
  "title": "Unknown",
  "type": "object"
}
