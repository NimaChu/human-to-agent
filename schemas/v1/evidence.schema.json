{
  "$defs": {
    "EvidenceBasis": {
      "enum": [
        "observed",
        "inferred",
        "assumption",
        "unverified"
      ],
      "title": "EvidenceBasis",
      "type": "string"
    },
    "EvidenceType": {
      "enum": [
        "formal_rule",
        "real_case",
        "owner_confirmation",
        "system_definition",
        "historical_data",
        "risk_decision",
        "repeatable_validation"
      ],
      "title": "EvidenceType",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "applicability_scope": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "title": "Applicability Scope",
      "type": "array"
    },
    "basis": {
      "$ref": "#/$defs/EvidenceBasis"
    },
    "captured_at": {
      "format": "date-time",
      "title": "Captured At",
      "type": "string"
    },
    "captured_by": {
      "minLength": 1,
      "title": "Captured By",
      "type": "string"
    },
    "cheapest_probe": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cheapest Probe"
    },
    "claim": {
      "minLength": 1,
      "title": "Claim",
      "type": "string"
    },
    "content_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Content Sha256",
      "type": "string"
    },
    "content_summary": {
      "minLength": 1,
      "title": "Content Summary",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "evidence_refs": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Evidence Refs",
      "type": "array"
    },
    "id": {
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "invalidation_conditions": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "title": "Invalidation Conditions",
      "type": "array"
    },
    "links": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Links",
      "type": "array"
    },
    "locator": {
      "minLength": 1,
      "title": "Locator",
      "type": "string"
    },
    "owners": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "title": "Owners",
      "type": "array"
    },
    "provenance": {
      "minLength": 1,
      "title": "Provenance",
      "type": "string"
    },
    "revision": {
      "minimum": 1,
      "title": "Revision",
      "type": "integer"
    },
    "schema_version": {
      "minLength": 1,
      "title": "Schema Version",
      "type": "string"
    },
    "source": {
      "minLength": 1,
      "title": "Source",
      "type": "string"
    },
    "status": {
      "minLength": 1,
      "title": "Status",
      "type": "string"
    },
    "type": {
      "$ref": "#/$defs/EvidenceType"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    },
    "validity_conditions": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "title": "Validity Conditions",
      "type": "array"
    },
    "workspace_id": {
      "minLength": 1,
      "title": "Workspace Id",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "id",
    "workspace_id",
    "revision",
    "status",
    "owners",
    "created_at",
    "updated_at",
    "provenance",
    "type",
    "source",
    "locator",
    "captured_by",
    "captured_at",
    "content_summary",
    "claim",
    "basis",
    "applicability_scope",
    "validity_conditions",
    "invalidation_conditions",
    "content_sha256"
  ],
  "title": "Evidence",
  "type": "object"
}
